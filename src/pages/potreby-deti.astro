---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { getCollection } from "astro:content";

const articles = await getCollection("blog", ({ data }) => {
    return data.category === "Potřeby dětí" && data.published === true;
});
---

<BaseLayout title="Potřeby dětí – Dítě v rozvodu">
    <!-- Topic Hero -->
    <header class="bg-gradient-to-r from-accent to-primary text-white py-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h1 class="text-4xl md:text-6xl font-bold mb-6">
                Co děti potřebují během rozvodu
            </h1>
            <p class="text-xl md:text-2xl opacity-90 max-w-3xl mx-auto mb-8">
                Rozvod je pro děti náročný, ale můžete jim pomoci. Zjistěte, co
                děti v této době nejvíc potřebují a jak jim to poskytnout. Děti
                během rozvodu potřebují především <strong
                    >stabilitu, jistotu a lásku obou rodičů</strong
                >. I když se vaše partnerství rozpadá, vaše rodičovství
                pokračuje. Následující články vám pomohou pochopit, co děti v
                této době prožívají a jak jim můžete pomoci.
            </p>
            <a
                href="https://spondea.thinkific.com/courses/jakmluvitsdetmi"
                class="inline-block bg-white text-primary px-8 py-3 rounded-full font-semibold hover:bg-gray-100 transition"
            >
                Naučte se mluvit s dětmi
            </a>
        </div>
    </header>

    <!-- Articles Grid -->
    <section class="py-12 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                {
                    articles.map((article) => (
                        <ArticleCard
                            title={article.data.title}
                            description={article.data.description}
                            category={article.data.category}
                            image={article.data.image}
                            slug={article.slug}
                            showCategory={false}
                        />
                    ))
                }
            </div>
        </div>
    </section>
</BaseLayout>
